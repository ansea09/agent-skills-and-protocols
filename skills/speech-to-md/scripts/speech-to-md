#!/usr/bin/env python3
from __future__ import annotations

import argparse
from dataclasses import dataclass
import hashlib
import json
import os
from pathlib import Path
import platform
import re
import shutil
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from typing import Any


SCHEMA = "speech-to-md.bundle.v1"
SEGMENTS_SCHEMA = "speech-to-md.segments.v1"
WHISPER_CPP_DIRECT_EXTENSIONS = {".wav", ".wave", ".mp3", ".flac"}
AUDIO_NORMALIZATION_MODES = {"auto", "always", "never"}


@dataclass(frozen=True)
class EngineAdapter:
    key: str
    display_name: str
    kind: str
    supports_diarization: bool = False
    supports_chunking: bool = False
    supports_cloud: bool = False


@dataclass(frozen=True)
class EngineRun:
    content: str
    segments: list[dict[str, Any]]
    engine: dict[str, Any]
    warnings: list[str]
    vtt_path: Path | None = None


ENGINE_ADAPTERS: dict[str, EngineAdapter] = {
    "whisper-cpp": EngineAdapter(
        key="whisper-cpp",
        display_name="whisper.cpp",
        kind="local-asr",
        supports_diarization=False,
        supports_chunking=False,
        supports_cloud=False,
    ),
}


def engine_choices() -> list[str]:
    return sorted(ENGINE_ADAPTERS)


def require_engine_adapter(name: str | None) -> EngineAdapter:
    key = name or "whisper-cpp"
    try:
        return ENGINE_ADAPTERS[key]
    except KeyError as exc:
        raise SystemExit(f"ERROR: unsupported ASR engine: {key}") from exc


def engine_capabilities(adapter: EngineAdapter) -> dict[str, Any]:
    return {
        "kind": adapter.kind,
        "diarization": adapter.supports_diarization,
        "chunking": adapter.supports_chunking,
        "cloud": adapter.supports_cloud,
    }


def utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def which(name: str) -> str | None:
    return shutil.which(name)


def configured_ffmpeg(args: argparse.Namespace | None = None) -> str | None:
    if args is not None and getattr(args, "ffmpeg_bin", None):
        return args.ffmpeg_bin
    return os.environ.get("SPEECH_TO_MD_FFMPEG_BIN") or which("ffmpeg")


def default_model_path() -> str | None:
    model_dir_env = os.environ.get("SPEECH_TO_MD_MODELS_DIR")
    model_dirs = []
    if model_dir_env:
        model_dirs.append(Path(model_dir_env).expanduser())
    model_dirs.extend(
        [
            Path(os.environ.get("CODEX_HOME", str(Path.home() / ".codex"))).expanduser() / "tools" / "whisper.cpp" / "models",
            Path.home() / ".codex" / "tools" / "whisper.cpp" / "models",
        ]
    )
    for model_dir in model_dirs:
        for name in ("ggml-medium-q8_0.bin", "ggml-medium.bin", "ggml-small-q8_0.bin", "ggml-small.bin"):
            candidate = model_dir / name
            if candidate.is_file():
                return str(candidate)
    return None


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def file_fingerprint(path: Path) -> dict[str, Any]:
    if not path.is_file():
        return {"path": str(path), "exists": False}
    return {
        "path": str(path),
        "exists": True,
        "size_bytes": path.stat().st_size,
        "sha256": sha256_file(path),
    }


def command_fingerprint(command: str | None, probe_args: list[str], timeout: int = 15) -> dict[str, Any] | None:
    if not command:
        return None
    path = Path(command).expanduser()
    resolved = shutil.which(command) if os.sep not in command else str(path)
    info: dict[str, Any] = {
        "path": resolved or command,
    }
    candidate = Path(resolved).expanduser() if resolved else path
    if candidate.is_file():
        info.update(
            {
                "exists": True,
                "size_bytes": candidate.stat().st_size,
                "sha256": sha256_file(candidate),
            }
        )
    else:
        info["exists"] = False
    try:
        proc = subprocess.run(
            [resolved or command, *probe_args],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
        )
        output = (proc.stdout or "").strip()
        lines = output.splitlines()
        info.update(
            {
                "probe_command": [resolved or command, *probe_args],
                "probe_returncode": proc.returncode,
                "probe_line": lines[0] if lines else "",
                "probe_output_tail": "\n".join(lines[-20:]),
            }
        )
    except Exception as exc:
        info.update(
            {
                "probe_command": [resolved or command, *probe_args],
                "probe_error": str(exc),
            }
        )
    return info


def whisper_cpp_source_commit(whisper_bin: str | None) -> str | None:
    if not whisper_bin:
        return None
    resolved = shutil.which(whisper_bin) if os.sep not in whisper_bin else whisper_bin
    if not resolved:
        return None
    for parent in Path(resolved).expanduser().resolve().parents:
        if parent.name == "whisper.cpp" and (parent / ".git").exists():
            try:
                proc = subprocess.run(
                    ["git", "-C", str(parent), "rev-parse", "HEAD"],
                    text=True,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.DEVNULL,
                    timeout=10,
                )
            except Exception:
                return None
            commit = proc.stdout.strip()
            return commit or None
    return None


def runtime_fingerprint(whisper_bin: str | None, model_path: Path | None, ffmpeg: str | None) -> dict[str, Any]:
    whisper_info = command_fingerprint(whisper_bin, ["--help"])
    if whisper_info is not None:
        whisper_info["source_commit"] = whisper_cpp_source_commit(whisper_bin)
    return {
        "whisper_cli": whisper_info,
        "model": file_fingerprint(model_path) if model_path is not None else None,
        "ffmpeg": command_fingerprint(ffmpeg, ["-version"]) if ffmpeg else None,
    }


def human_size(path: Path) -> str:
    size = path.stat().st_size
    units = ["B", "KB", "MB", "GB", "TB"]
    value = float(size)
    for unit in units:
        if value < 1024 or unit == units[-1]:
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024
    return f"{size} B"


def seconds_label(value: float | int | None) -> str | None:
    if value is None:
        return None
    total_ms = int(round(float(value) * 1000))
    ms = total_ms % 1000
    total_seconds = total_ms // 1000
    seconds = total_seconds % 60
    total_minutes = total_seconds // 60
    minutes = total_minutes % 60
    hours = total_minutes // 60
    return f"{hours:02d}:{minutes:02d}:{seconds:02d}.{ms:03d}"


def parse_timestamp(value: Any) -> float | None:
    if value is None:
        return None
    if isinstance(value, (int, float)):
        return float(value)
    text = str(value).strip()
    if not text:
        return None
    if re.fullmatch(r"\d+(\.\d+)?", text):
        return float(text)
    match = re.fullmatch(r"(?:(\d+):)?(\d{1,2}):(\d{1,2})(?:[.,](\d{1,3}))?", text)
    if not match:
        return None
    hours = int(match.group(1) or 0)
    minutes = int(match.group(2))
    seconds = int(match.group(3))
    ms = int((match.group(4) or "0").ljust(3, "0"))
    return hours * 3600 + minutes * 60 + seconds + ms / 1000


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="replace")


def normalize_text(text: str) -> str:
    lines = [line.rstrip() for line in text.replace("\r\n", "\n").replace("\r", "\n").split("\n")]
    while lines and not lines[0].strip():
        lines.pop(0)
    while lines and not lines[-1].strip():
        lines.pop()
    return "\n".join(lines).strip() + ("\n" if lines else "")


def segment_from_text(text: str) -> list[dict[str, Any]]:
    clean = normalize_text(text).strip()
    if not clean:
        return []
    return [
        {
            "index": 1,
            "start": None,
            "end": None,
            "start_label": None,
            "end_label": None,
            "speaker": None,
            "text": clean,
        }
    ]


def coerce_segment(raw: dict[str, Any], index: int) -> dict[str, Any]:
    timestamps = raw.get("timestamps") if isinstance(raw.get("timestamps"), dict) else {}
    offsets = raw.get("offsets") if isinstance(raw.get("offsets"), dict) else {}
    start = raw.get("start")
    end = raw.get("end")
    if start is None:
        start = timestamps.get("from") or offsets.get("from")
    if end is None:
        end = timestamps.get("to") or offsets.get("to")
    start_s = parse_timestamp(start)
    end_s = parse_timestamp(end)
    if start_s is not None and isinstance(start, int) and start > 10000:
        start_s = start / 1000
    if end_s is not None and isinstance(end, int) and end > 10000:
        end_s = end / 1000
    return {
        "index": index,
        "start": start_s,
        "end": end_s,
        "start_label": seconds_label(start_s),
        "end_label": seconds_label(end_s),
        "speaker": raw.get("speaker"),
        "text": str(raw.get("text") or raw.get("sentence") or "").strip(),
    }


def parse_transcript_payload(path: Path) -> tuple[str, list[dict[str, Any]], str]:
    text = read_text(path)
    if path.suffix.lower() == ".json":
        try:
            payload = json.loads(text)
        except json.JSONDecodeError:
            return normalize_text(text), segment_from_text(text), "text"
        candidate = None
        if isinstance(payload, dict):
            for key in ("segments", "transcription", "results"):
                if isinstance(payload.get(key), list):
                    candidate = payload[key]
                    break
        elif isinstance(payload, list):
            candidate = payload
        if candidate is not None:
            segments = [
                coerce_segment(item, idx)
                for idx, item in enumerate(candidate, start=1)
                if isinstance(item, dict)
            ]
            segments = [item for item in segments if item["text"]]
            content = "\n\n".join(item["text"] for item in segments).strip()
            return normalize_text(content), segments, "json"
    return normalize_text(text), segment_from_text(text), "text"


def doctor_payload(args: argparse.Namespace) -> dict[str, Any]:
    adapter = require_engine_adapter(getattr(args, "engine", None))
    whisper_bin = args.whisper_bin or os.environ.get("SPEECH_TO_MD_WHISPER_CPP_BIN") or which("whisper-cli")
    model = args.model or os.environ.get("SPEECH_TO_MD_WHISPER_CPP_MODEL") or default_model_path()
    model_path = Path(model).expanduser() if model else None
    checks: list[dict[str, Any]] = []
    checks.append({"name": "python", "status": "ok", "detail": sys.version.split()[0]})
    checks.append({"name": "platform", "status": "ok", "detail": f"{platform.system()} {platform.machine()}"})
    checks.append({"name": "engine", "status": "ok", "detail": f"{adapter.key} ({adapter.kind})"})
    if whisper_bin:
        checks.append({"name": "whisper-cli", "status": "ok", "detail": whisper_bin})
    else:
        checks.append({"name": "whisper-cli", "status": "warn", "detail": "not found on PATH; transcript import still works"})
    if model:
        if model_path and model_path.is_file():
            checks.append({"name": "whisper-model", "status": "ok", "detail": str(model_path)})
        else:
            checks.append({"name": "whisper-model", "status": "fail", "detail": f"model file not found: {model_path}"})
    else:
        checks.append({"name": "whisper-model", "status": "warn", "detail": "set SPEECH_TO_MD_WHISPER_CPP_MODEL, set SPEECH_TO_MD_MODELS_DIR, or pass --model"})
    ffmpeg = configured_ffmpeg(args)
    checks.append({"name": "ffmpeg", "status": "ok" if ffmpeg else "warn", "detail": ffmpeg or "not found; some audio normalization paths may be unavailable"})
    if any(item["status"] == "fail" for item in checks):
        status = "fail"
    elif any(item["status"] == "warn" for item in checks):
        status = "warn"
    else:
        status = "ok"
    return {
        "schema": "speech-to-md.doctor.v1",
        "checked_at": utc_now(),
        "status": status,
        "checks": checks,
        "runtime": runtime_fingerprint(whisper_bin, model_path, ffmpeg),
    }


def print_doctor(args: argparse.Namespace) -> int:
    payload = doctor_payload(args)
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"speech-to-md doctor: {payload['status']}")
        for check in payload["checks"]:
            print(f"- {check['name']}: {check['status']} - {check['detail']}")
    return 0 if payload["status"] in {"ok", "warn"} else 1


def should_normalize_audio(source: Path, mode: str) -> tuple[bool, str]:
    if mode == "never":
        return False, "disabled"
    if mode == "always":
        return True, "forced"
    suffix = source.suffix.lower()
    if suffix in WHISPER_CPP_DIRECT_EXTENSIONS:
        return False, f"{suffix or 'extensionless'} is passed directly to whisper.cpp"
    return True, f"{suffix or 'extensionless'} is normalized for whisper.cpp compatibility"


def normalize_audio_for_whisper(source: Path, work_dir: Path, args: argparse.Namespace, mode: str) -> tuple[Path, dict[str, Any]]:
    use_normalization, reason = should_normalize_audio(source, mode)
    info: dict[str, Any] = {
        "mode": mode,
        "normalized": False,
        "reason": reason,
        "input": str(source),
    }
    if not use_normalization:
        return source, info
    ffmpeg = configured_ffmpeg(args)
    if not ffmpeg:
        raise SystemExit(
            "ERROR: ffmpeg is required for this audio container. Install ffmpeg, pass --ffmpeg-bin, "
            "or retry with --audio-normalization never for formats whisper.cpp can read directly."
        )
    output = work_dir / "normalized-audio.wav"
    command = [
        ffmpeg,
        "-y",
        "-hide_banner",
        "-loglevel",
        "error",
        "-i",
        str(source),
        "-vn",
        "-ac",
        "1",
        "-ar",
        "16000",
        "-c:a",
        "pcm_s16le",
        str(output),
    ]
    proc = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=args.timeout)
    info.update(
        {
            "normalized": True,
            "command": [*command[:-1], "<normalized-audio.wav>"],
            "output_retained": False,
            "output_format": "wav",
            "codec": "pcm_s16le",
            "sample_rate_hz": 16000,
            "channels": 1,
            "returncode": proc.returncode,
            "output_tail": "\n".join((proc.stdout or "").splitlines()[-40:]),
            "ffmpeg": command_fingerprint(ffmpeg, ["-version"]),
        }
    )
    if proc.returncode != 0:
        raise RuntimeError("ffmpeg audio normalization failed:\n" + (proc.stdout or "").strip())
    if not output.is_file() or output.stat().st_size == 0:
        raise RuntimeError("ffmpeg audio normalization produced no usable WAV output.")
    info.update(
        {
            "normalized_size_bytes": output.stat().st_size,
            "normalized_sha256": sha256_file(output),
        }
    )
    return output, info


def run_whisper_cpp(args: argparse.Namespace, work_dir: Path) -> EngineRun:
    source = args.source
    if source is None:
        raise SystemExit("ERROR: source audio file is required unless --transcript is used")
    if not source.is_file():
        raise SystemExit(f"ERROR: source audio file not found: {source}")
    max_bytes = args.max_input_mb * 1024 * 1024
    if args.max_input_mb > 0 and source.stat().st_size > max_bytes:
        raise SystemExit(f"ERROR: input exceeds --max-input-mb {args.max_input_mb}: {source}")
    whisper_bin = args.whisper_bin or os.environ.get("SPEECH_TO_MD_WHISPER_CPP_BIN") or which("whisper-cli")
    if not whisper_bin:
        raise SystemExit("ERROR: whisper-cli not found. Install whisper.cpp or use --transcript to package an existing transcript.")
    model = args.model or os.environ.get("SPEECH_TO_MD_WHISPER_CPP_MODEL") or default_model_path()
    if not model:
        raise SystemExit("ERROR: missing model. Pass --model, set SPEECH_TO_MD_WHISPER_CPP_MODEL, or set SPEECH_TO_MD_MODELS_DIR.")
    model_path = Path(model).expanduser()
    if not model_path.is_file():
        raise SystemExit(f"ERROR: model file not found: {model_path}")
    normalization_mode = args.audio_normalization
    if normalization_mode not in AUDIO_NORMALIZATION_MODES:
        raise SystemExit(f"ERROR: invalid --audio-normalization value: {normalization_mode}")
    audio_input, audio_preprocess = normalize_audio_for_whisper(source, work_dir, args, normalization_mode)

    prefix = work_dir / "whisper-output"
    command = [whisper_bin, "-m", str(model_path), "-f", str(audio_input), "-oj", "-otxt", "-ovtt", "-of", str(prefix)]
    manifest_command = [
        whisper_bin,
        "-m",
        str(model_path),
        "-f",
        "<normalized-audio.wav>" if audio_preprocess.get("normalized") else str(source),
        "-oj",
        "-otxt",
        "-ovtt",
        "-of",
        "<work-dir>/whisper-output",
    ]
    if args.language:
        command.extend(["-l", args.language])
        manifest_command.extend(["-l", args.language])
    no_gpu = args.no_gpu or os.environ.get("SPEECH_TO_MD_WHISPER_CPP_NO_GPU") in {"1", "true", "yes", "on"}
    if no_gpu:
        command.append("-ng")
        manifest_command.append("-ng")
    proc = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=args.timeout)
    engine = {
        "name": "whisper.cpp",
        "adapter": "whisper-cpp",
        "contract": "speech-to-md.asr-engine.v1",
        "capabilities": engine_capabilities(require_engine_adapter("whisper-cpp")),
        "command": manifest_command,
        "returncode": proc.returncode,
        "output_tail": "\n".join((proc.stdout or "").splitlines()[-80:]),
        "model": str(model_path),
        "language": args.language,
        "no_gpu": no_gpu,
        "audio_input": {
            "kind": "normalized-wav" if audio_preprocess.get("normalized") else "source",
            "path": None if audio_preprocess.get("normalized") else str(source),
            "retained": not bool(audio_preprocess.get("normalized")),
            "format": "wav" if audio_preprocess.get("normalized") else source.suffix.lower().lstrip("."),
        },
        "audio_preprocess": audio_preprocess,
        "runtime": runtime_fingerprint(whisper_bin, model_path, configured_ffmpeg(args)),
    }
    if proc.returncode != 0:
        raise RuntimeError("whisper.cpp failed:\n" + (proc.stdout or "").strip())
    json_path = prefix.with_suffix(".json")
    txt_path = prefix.with_suffix(".txt")
    vtt_path = prefix.with_suffix(".vtt")
    warnings: list[str] = []
    if json_path.is_file():
        content, segments, _ = parse_transcript_payload(json_path)
    elif txt_path.is_file():
        content, segments, _ = parse_transcript_payload(txt_path)
        warnings.append("whisper.cpp did not emit JSON; segments are not timestamped.")
    else:
        raise RuntimeError("whisper.cpp completed but produced no JSON or TXT transcript.")
    if vtt_path.is_file():
        engine["vtt_path"] = str(vtt_path)
    return EngineRun(content=content, segments=segments, engine=engine, warnings=warnings, vtt_path=vtt_path if vtt_path.is_file() else None)


def run_asr_engine(args: argparse.Namespace, work_dir: Path) -> EngineRun:
    adapter = require_engine_adapter(args.engine)
    if adapter.key == "whisper-cpp":
        return run_whisper_cpp(args, work_dir)
    raise SystemExit(f"ERROR: unsupported ASR engine: {adapter.key}")


def write_bundle(
    *,
    output_dir: Path,
    source_audio: Path | None,
    transcript_path: Path | None,
    content: str,
    segments: list[dict[str, Any]],
    engine: dict[str, Any],
    warnings: list[str],
    import_kind: str | None,
    vtt_path: Path | None,
) -> None:
    output_dir.mkdir(parents=True, exist_ok=False)
    source_record: dict[str, Any] = {}
    if source_audio:
        source_record = {
            "path": str(source_audio),
            "name": source_audio.name,
            "size_bytes": source_audio.stat().st_size if source_audio.is_file() else None,
            "size_human": human_size(source_audio) if source_audio.is_file() else None,
            "sha256": sha256_file(source_audio) if source_audio.is_file() else None,
        }
    files = [
        "LLM_README.md",
        "content.md",
        "segments.md",
        "segments.json",
        "manifest.json",
        "audit.md",
        "conversion-report.md",
    ]
    if vtt_path and vtt_path.is_file():
        shutil.copy2(vtt_path, output_dir / "timestamps.vtt")
        files.append("timestamps.vtt")

    (output_dir / "content.md").write_text("# Transcript\n\n" + normalize_text(content), encoding="utf-8")
    segment_lines = ["# Timestamped Segments", ""]
    if segments:
        for segment in segments:
            start = segment.get("start_label") or "unknown"
            end = segment.get("end_label") or "unknown"
            speaker = segment.get("speaker") or "speaker-not-attributed"
            segment_lines.append(f"## Segment {segment['index']} [{start} - {end}]")
            segment_lines.append("")
            segment_lines.append(f"Speaker: `{speaker}`")
            segment_lines.append("")
            segment_lines.append(segment["text"])
            segment_lines.append("")
    else:
        segment_lines.append("No timestamped segments were available.")
        segment_lines.append("")
    (output_dir / "segments.md").write_text("\n".join(segment_lines), encoding="utf-8")
    (output_dir / "segments.json").write_text(
        json.dumps({"schema": SEGMENTS_SCHEMA, "segments": segments}, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )

    manifest = {
        "schema": SCHEMA,
        "created_at": utc_now(),
        "source_audio": source_record,
        "transcript_import": str(transcript_path) if transcript_path else None,
        "transcript_import_kind": import_kind,
        "engine": engine,
        "warnings": warnings,
        "files": files,
    }
    (output_dir / "manifest.json").write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n", encoding="utf-8")

    warning_lines = warnings or ["No wrapper-level warnings."]
    audit = [
        "# Audio Transcript Audit",
        "",
        f"- Generated at: `{manifest['created_at']}`",
        f"- Engine: `{engine.get('name', 'unknown')}`",
        f"- Source audio: `{source_record.get('path') or 'not provided'}`",
        f"- Transcript import: `{str(transcript_path) if transcript_path else 'none'}`",
        f"- Segment count: `{len(segments)}`",
        f"- Diarization: `not-provided`",
        f"- Speaker identity: `not-provided`",
        "",
        "## Warnings",
        "",
    ]
    audit.extend(f"- {item}" for item in warning_lines)
    audit.extend(
        [
            "",
            "## Trust Boundary",
            "",
            "This bundle contains ASR or imported transcript output. Treat exact quotes, speaker attribution, and missing-content claims as uncertain unless source audio was reviewed.",
        ]
    )
    (output_dir / "audit.md").write_text("\n".join(audit) + "\n", encoding="utf-8")

    readme = [
        "# LLM Readme",
        "",
        "Read `content.md` first for the clean transcript.",
        "",
        "Before making quote-sensitive, speaker-sensitive, or quality-sensitive claims, inspect `audit.md` and `segments.json`.",
        "",
        "Do not infer speaker identity or diarization from this bundle unless those fields are explicitly present.",
        "",
        "Use `segments.md` or `segments.json` when timestamps matter.",
    ]
    (output_dir / "LLM_README.md").write_text("\n".join(readme) + "\n", encoding="utf-8")

    report = [
        "# Conversion Report",
        "",
        f"- Status: `ok`",
        f"- Engine: `{engine.get('name', 'unknown')}`",
        f"- Output bundle: `{output_dir}`",
        f"- Segment count: `{len(segments)}`",
        f"- Warnings: `{len(warnings)}`",
        "",
    ]
    (output_dir / "conversion-report.md").write_text("\n".join(report), encoding="utf-8")


def output_exists(path: Path) -> bool:
    return path.exists() or path.is_symlink()


def publish_bundle(bundle_dir: Path, output_dir: Path, staging: Path, force: bool) -> None:
    previous = staging / "previous-output"
    moved_previous = False
    if output_exists(output_dir):
        if not force:
            raise SystemExit(f"ERROR: output exists; pass --force to replace it: {output_dir}")
        output_dir.replace(previous)
        moved_previous = True
    try:
        bundle_dir.replace(output_dir)
    except Exception:
        if moved_previous and output_exists(previous) and not output_exists(output_dir):
            previous.replace(output_dir)
        raise


def build_bundle(args: argparse.Namespace) -> int:
    output_dir = args.output.expanduser().resolve()
    if output_exists(output_dir):
        if not args.force:
            raise SystemExit(f"ERROR: output exists; pass --force to replace it: {output_dir}")
    output_dir.parent.mkdir(parents=True, exist_ok=True)
    staging = Path(tempfile.mkdtemp(prefix=f".{output_dir.name}.", dir=str(output_dir.parent)))
    work_dir = staging / "work"
    bundle_dir = staging / "bundle"
    work_dir.mkdir()
    try:
        warnings: list[str] = []
        transcript_path = args.transcript.expanduser().resolve() if args.transcript else None
        source_audio = args.source_audio.expanduser().resolve() if args.source_audio else None
        import_kind = None
        vtt_path = None
        if transcript_path:
            if not transcript_path.is_file():
                raise SystemExit(f"ERROR: transcript not found: {transcript_path}")
            content, segments, import_kind = parse_transcript_payload(transcript_path)
            engine = {"name": "transcript-import", "transcript": str(transcript_path)}
            if source_audio and not source_audio.is_file():
                warnings.append(f"source audio path was recorded but not found: {source_audio}")
        else:
            args.source = args.source.expanduser().resolve() if args.source else None
            source_audio = args.source
            engine_run = run_asr_engine(args, work_dir)
            content = engine_run.content
            segments = engine_run.segments
            engine = engine_run.engine
            warnings.extend(engine_run.warnings)
            vtt_path = engine_run.vtt_path
        if not normalize_text(content).strip():
            warnings.append("transcript content is empty.")
        if not segments:
            warnings.append("no segment records were available.")
        write_bundle(
            output_dir=bundle_dir,
            source_audio=source_audio,
            transcript_path=transcript_path,
            content=content,
            segments=segments,
            engine=engine,
            warnings=warnings,
            import_kind=import_kind,
            vtt_path=vtt_path,
        )
        publish_bundle(bundle_dir, output_dir, staging, args.force)
    finally:
        if staging.exists():
            shutil.rmtree(staging, ignore_errors=True)
    print(f"Created speech-to-md bundle: {output_dir}")
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Convert trusted local speech audio or transcripts to Markdown bundles.")
    parser.add_argument("source", nargs="?", type=Path, help="Trusted local speech audio file.")
    parser.add_argument("-o", "--output", type=Path, help="Output bundle directory.")
    parser.add_argument("--transcript", type=Path, help="Package an existing transcript text or JSON file instead of running ASR.")
    parser.add_argument("--source-audio", type=Path, help="Source audio path to record when using --transcript.")
    parser.add_argument("--engine", choices=engine_choices(), default="whisper-cpp")
    parser.add_argument("--model", help="whisper.cpp model path; defaults to SPEECH_TO_MD_WHISPER_CPP_MODEL.")
    parser.add_argument("--whisper-bin", help="Path to whisper-cli; defaults to SPEECH_TO_MD_WHISPER_CPP_BIN or PATH.")
    parser.add_argument("--ffmpeg-bin", help="Path to ffmpeg; defaults to SPEECH_TO_MD_FFMPEG_BIN or PATH.")
    parser.add_argument("--language", help="Optional language code passed to whisper.cpp.")
    parser.add_argument("--no-gpu", action="store_true", help="Pass -ng to whisper-cli; also available with SPEECH_TO_MD_WHISPER_CPP_NO_GPU=1.")
    parser.add_argument(
        "--audio-normalization",
        choices=sorted(AUDIO_NORMALIZATION_MODES),
        default=os.environ.get("SPEECH_TO_MD_AUDIO_NORMALIZATION", "auto"),
        help="Use ffmpeg to normalize audio to mono 16 kHz WAV: auto for non-native containers, always, or never.",
    )
    parser.add_argument("--timeout", type=int, default=1800)
    parser.add_argument("--max-input-mb", type=int, default=2048)
    parser.add_argument("--force", action="store_true", help="Replace an existing output bundle.")
    parser.add_argument("--doctor", action="store_true")
    parser.add_argument("--json", action="store_true", help="Machine-readable doctor output.")
    args = parser.parse_args(argv)

    if args.doctor:
        return print_doctor(args)
    if not args.output:
        raise SystemExit("ERROR: -o/--output is required unless --doctor is used")
    if not args.transcript and not args.source:
        raise SystemExit("ERROR: source audio file is required unless --transcript is used")
    return build_bundle(args)


if __name__ == "__main__":
    raise SystemExit(main())
